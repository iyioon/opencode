{
	"$schema": "https://opencode.ai/config.json",
	"model": "github-copilot/claude-sonnet-4.6",
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
			},
			"enabled": true
		},
		"gh_grep": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		}
	},
	"permission": {
		"external_directory": {
			"~/.config/opencode/worktrees/**": "allow"
		}
	}
}
